<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="#0C012F"
    android:orientation="vertical">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FACE DETECTION"
        android:layout_marginTop="25dp"
        android:textColor="#767575"
        android:layout_marginLeft="35dp"
        android:textStyle="bold"
        android:textSize="40dp"/>
   <androidx.cardview.widget.CardView
       android:layout_width="300dp"
       android:layout_height="480dp"
       android:layout_marginTop="30dp"
       android:layout_marginLeft="39dp">

       <ImageButton
           android:id="@+id/image"
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           tools:ignore="SpeakableTextPresentCheck" />
       <TextView
           android:id="@+id/text5"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Click To View"
           android:layout_marginTop="10dp"
           android:layout_gravity="center"
           android:textStyle="bold"
           android:textSize="20dp"/>
   </androidx.cardview.widget.CardView>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">
    <ImageView
        android:id="@+id/sadid"
        android:layout_width="60dp"
        android:layout_height="65dp"
        android:layout_marginLeft="45dp"
        android:background="@drawable/customimg"
        android:src="@drawable/sad"
        android:visibility="invisible"/>
    <ImageView
        id="@+id/jollyid"
        android:layout_width="60dp"
        android:layout_height="65dp"
        android:layout_marginLeft="45dp"
        android:visibility="invisible"
        android:background="@drawable/customimg"
        android:src="@drawable/jolly"
        tools:ignore="MissingPrefix" />
    <ImageView
       android:id="@+id/happyid"
    android:layout_width="60dp"
    android:layout_height="65dp"
    android:visibility="invisible"
    android:layout_marginLeft="60dp"
    android:background="@drawable/customimg"
    android:src="@drawable/happiness"/>
</LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
    <TextView
        android:id="@+id/text1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Left Eye data"
        android:textColor="#9E9D9D"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="45dp"
        android:visibility="invisible"
        android:textStyle="bold"
        android:textSize="20dp"/>

    <TextView
        android:id="@+id/text2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Right Eye data"
        android:layout_marginTop="30dp"
        android:textColor="#9E9D9D"
        android:layout_marginLeft="45dp"
        android:visibility="invisible"
        android:textStyle="bold"
        android:textSize="20dp"/>
    </LinearLayout>
</LinearLayout>